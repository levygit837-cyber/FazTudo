# Server
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://faztudo:faztudo_dev_2026@localhost:5432/faztudo

# Redis (for BullMQ queues and caching)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-secret-here-min-32-chars-for-production
JWT_ACCESS_SECRET=    # Separate access token secret (falls back to JWT_SECRET)
JWT_REFRESH_SECRET=   # Separate refresh token secret (falls back to JWT_SECRET)
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# Security
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
SENSITIVE_RATE_LIMIT_MAX=5
FINANCIAL_RATE_LIMIT_MAX=3
WEBHOOK_RATE_LIMIT_MAX=100
MFA_RATE_LIMIT_MAX=5
BODY_SIZE_LIMIT=10kb

# Trust Proxy (number of hops, e.g. 1 for single reverse proxy)
TRUST_PROXY=1

# Escrow
DEFAULT_ESCROW_HOLD_DAYS=7
ESCROW_AUTO_RELEASE_DAYS=2
PLATFORM_FEE_PERCENTAGE=10.0

# Mercado Pago (NUNCA commitar valores reais!)
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_SANDBOX=true

# Webhook secret from MercadoPago dashboard (required in production)
MP_WEBHOOK_SECRET=

# Notifications
ENABLE_EMAIL_NOTIFICATIONS=false

# Email (SMTP - Brevo em produção, Ethereal em dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=FazTudo
SMTP_FROM_EMAIL=noreply@faztudo.com.br

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5173

# URL pública do backend (necessária para webhooks do MercadoPago)
# Em dev: usar ngrok ou similar. Ex: https://abc123.ngrok.io
# Em produção: URL real do servidor
BACKEND_URL=

# Dev only: allow payment bypass without real MercadoPago (NEVER set to true in production)
ALLOW_LOCAL_PAYMENT_FALLBACK=false

# MFA (TOTP) - encryption key for secrets (min 32 chars, required in production)
MFA_ENCRYPTION_KEY=

# Secrets provider (env | aws | gcp | azure) - default: env
SECRETS_PROVIDER=env

# Object Storage (S3-compatible: AWS S3, MinIO, Cloudflare R2, DigitalOcean Spaces)
STORAGE_PROVIDER=local
S3_BUCKET=faztudo-uploads
S3_REGION=us-east-1
S3_ENDPOINT=                    # MinIO/R2/DO Spaces custom endpoint
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=                  # CDN or public URL prefix for public assets
UPLOAD_PRESIGN_EXPIRY_SECONDS=300
DOWNLOAD_PRESIGN_EXPIRY_SECONDS=3600

# Health endpoint auth (optional; allows VPC/network access beyond localhost)
HEALTH_AUTH_TOKEN=
