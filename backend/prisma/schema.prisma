generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Enums
enum UserRole {
  CLIENT
  PROFESSIONAL
  COMPANY
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum ServiceOrderStatus {
  DRAFT // Rascunho - conversa antes de formalizar pedido
  PENDING // Aguardando aceitação do profissional
  ACCEPTED // Aceito pelo profissional
  IN_PROGRESS // Em andamento
  AWAITING_CLIENT_CONFIRMATION // Serviço entregue pelo profissional, aguardando cliente confirmar conclusão
  AWAITING_PROFESSIONAL_CONFIRMATION // Cliente confirmou, aguardando profissional confirmar conclusão
  COMPLETED // Concluído
  CANCELLED // Cancelado
  EXPIRED // Prazo expirado
  DISPUTED // Em disputa
}

enum PaymentStatus {
  PENDING // Aguardando pagamento
  HELD // Em escrow (aguardando conclusão)
  RELEASED // Liberado para profissional
  REFUNDED // Reembolsado
  FAILED // Falhou
  PARTIALLY_REFUNDED // Parcialmente reembolsado
}

enum NotificationType {
  ORDER_CREATED
  ORDER_ACCEPTED
  ORDER_COMPLETED
  ORDER_CANCELLED
  PAYMENT_RECEIVED
  PAYMENT_RELEASED
  DEADLINE_WARNING
  DEADLINE_EXPIRED
  NEW_MESSAGE
  REVIEW_RECEIVED
  SYSTEM_ALERT
  PROFESSIONAL_EN_ROUTE
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum ServiceCategoryType {
  HOME_SERVICES
  BUSINESS_SERVICES
  BOTH
}

enum VerificationType {
  DOCUMENT
  FACIAL
}

enum VerificationSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SalaryStatus {
  PENDING
  PAID
  FAILED
}

// Models
model User {
  id            Int        @id @default(autoincrement())
  email         String     @unique
  name          String
  phone         String?
  password      String
  role          UserRole   @default(CLIENT)
  status        UserStatus @default(PENDING)
  document      String?    @unique // CPF/CNPJ
  isVerified    Boolean    @default(false)
  bio           String?
  profileImage  String?
  ratingAverage Float      @default(0.0)
  totalReviews  Int        @default(0)
  balance       Float      @default(0.0)
  tokenVersion  Int        @default(0)
  refreshToken         String?
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?
  emailVerified          Boolean   @default(false)
  emailVerifyToken       String?   @unique
  emailVerifyExpires     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Professional specific fields
  categories      ProfessionalCategory[] // Categorias que o profissional atende
  serviceListings ServiceListing[] // Catálogo de serviços oferecidos
  certifications  Certification[] // Certificações do profissional

  // Relations
  addresses              Address[]
  serviceOrders          ServiceOrder[] @relation("ClientOrders")
  servicesProvided       ServiceOrder[] @relation("ProfessionalOrders")
  reviewsGiven           Review[]       @relation("ReviewAuthor")
  reviewsReceived        Review[]       @relation("ReviewTarget")
  notifications          Notification[]
  messagesSent           Message[]      @relation("Sender")
  messagesReceived       Message[]      @relation("Recipient")
  transactions           Transaction[]
  paymentsAsClient       Payment[]      @relation("PaymentClient")
  paymentsAsProfessional Payment[]      @relation("PaymentProfessional")
  files                  File[]
  verificationSubmissions VerificationSubmission[]
  proposals              Proposal[]     @relation("ProposalProfessional")
  schedule               ProfessionalSchedule[] @relation("ProfessionalSchedule")
  scheduleBlocks         ScheduleBlock[]        @relation("ScheduleBlocks")
  disputesInitiated      Dispute[]      @relation("DisputeInitiator")
  sessions               UserSession[]
  companyProfile         CompanyProfile?
  companyMember          CompanyMember?

  @@index([email])
  @@index([role])
  @@index([status])
}

model ServiceCategory {
  id                     Int                    @id @default(autoincrement())
  name                   String                 @unique
  description            String?
  icon                   String?
  type                   ServiceCategoryType    @default(HOME_SERVICES)
  parentCategoryId       Int?
  parentCategory         ServiceCategory?       @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  subcategories          ServiceCategory[]      @relation("CategoryHierarchy")
  serviceListings        ServiceListing[]
  professionalCategories ProfessionalCategory[]
  orderBriefs            OrderBrief[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentCategoryId])
  @@index([type])
}

model ProfessionalCategory {
  id              Int     @id @default(autoincrement())
  userId          Int
  categoryId      Int
  experienceYears Int?    @default(0)
  hourlyRate      Float?
  isPrimary       Boolean @default(false)

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, categoryId])
  @@index([userId])
  @@index([categoryId])
}

model ServiceListing {
  id             Int     @id @default(autoincrement())
  title          String
  description    String
  price          Float
  estimatedHours Int? // Tempo estimado em horas
  isAvailable    Boolean @default(true)
  images         Json // URLs das imagens (array como JSON)
  tags           Json // Tags para busca (array como JSON)

  // Relations
  professionalId Int
  categoryId     Int
  serviceOrders  ServiceOrder[]

  professional User            @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  category     ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([professionalId])
  @@index([categoryId])
  @@index([isAvailable])
}

model ServiceOrder {
  id            Int                @id @default(autoincrement())
  title         String
  description   String?
  price         Float
  status        ServiceOrderStatus @default(PENDING)
  scheduledDate DateTime? // Data agendada para o serviço
  deadlineDays  Int                @default(7) // Prazo em dias para conclusão
  deadlineDate  DateTime? // Data limite calculada
  startedAt     DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?

  // Confirmação dupla de conclusão
  clientConfirmedAt       DateTime?
  professionalConfirmedAt DateTime?

  // DRAFT conversion flow
  convertProposedBy Int?    // userId who proposed converting DRAFT to order
  convertStatus     String? // "PROPOSED", "ACCEPTED", "REJECTED"

  // Professional en-route tracking
  enRouteAt DateTime?

  // Localização do serviço
  addressId    Int?
  addressNotes String? // Informações adicionais sobre localização

  // Relations
  clientId         Int
  professionalId   Int?
  serviceListingId Int?
  address          Address?        @relation(fields: [addressId], references: [id])
  client           User            @relation("ClientOrders", fields: [clientId], references: [id], onDelete: Cascade)
  professional     User?           @relation("ProfessionalOrders", fields: [professionalId], references: [id], onDelete: SetNull)
  serviceListing   ServiceListing? @relation(fields: [serviceListingId], references: [id], onDelete: SetNull)

  // Associated data
  payments      Payment[]
  reviews       Review[]
  notifications Notification[]
  messages      Message[]
  files         File[]
  brief         OrderBrief?
  proposals     Proposal[]
  scheduleBlock ScheduleBlock?
  disputes      Dispute[]
  team          ServiceTeam?

  // Reschedule approval flow
  rescheduleProposedDate DateTime?
  rescheduleReason       String?
  rescheduleStatus       String?    // "PENDING", null (cleared after accept/reject)
  rescheduleRequestedBy  Int?       // userId who requested

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([professionalId])
  @@index([status])
  @@index([deadlineDate])
  @@index([createdAt])
  @@index([professionalId, status])
  @@index([clientId, status])
}

model Payment {
  id            Int           @id @default(autoincrement())
  amount        Float
  status        PaymentStatus @default(PENDING)
  paymentMethod String // cartão, pix, boleto, etc.
  transactionId String? // ID da transação no gateway
  metadata      Json? // Dados adicionais do gateway

  // Datas importantes
  dueDate    DateTime? // Data de vencimento (para boleto)
  paidAt     DateTime? // Quando foi pago
  heldUntil  DateTime? // Data até quando fica em escrow
  releasedAt DateTime? // Quando foi liberado para profissional
  refundedAt DateTime? // Quando foi reembolsado

  // Relations
  serviceOrderId Int
  clientId       Int
  professionalId Int?

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  client       User         @relation("PaymentClient", fields: [clientId], references: [id], onDelete: Cascade)
  professional User?        @relation("PaymentProfessional", fields: [professionalId], references: [id], onDelete: SetNull)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceOrderId])
  @@index([clientId])
  @@index([professionalId])
  @@index([status])
  @@index([paidAt])
  @@index([serviceOrderId, status])
}

model Transaction {
  id            Int    @id @default(autoincrement())
  type          String // DEPOSIT, WITHDRAWAL, PAYMENT, REFUND, FEE
  amount        Float
  description   String
  balanceBefore Float
  balanceAfter  Float

  // Relations
  userId    Int
  paymentId Int?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([paymentId])
  @@index([createdAt])
  @@index([type])
}

model Review {
  id             Int     @id @default(autoincrement())
  rating         Int
  comment        String?
  isProfessional Boolean // Se a review é sobre um profissional (true) ou cliente (false)

  // Relations
  authorId       Int
  targetId       Int
  serviceOrderId Int

  author       User         @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target       User         @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([authorId, serviceOrderId])
  @@index([targetId])
  @@index([serviceOrderId])
  @@index([createdAt])
}

model Notification {
  id       Int                @id @default(autoincrement())
  type     NotificationType
  title    String
  message  String
  status   NotificationStatus @default(UNREAD)
  metadata Json? // Dados adicionais (IDs relacionados)

  // Relations
  userId         Int
  serviceOrderId Int?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId])
  @@index([serviceOrderId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
}

model Address {
  id           Int     @id @default(autoincrement())
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  country      String  @default("Brasil")
  latitude     Float?
  longitude    Float?

  // Relations
  userId        Int
  serviceOrders ServiceOrder[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([zipCode])
  @@index([city, state])
}

model Message {
  id      Int     @id @default(autoincrement())
  content String
  isRead  Boolean @default(false)
  type    String  @default("TEXT") // TEXT, SYSTEM, ATTACHMENT, LOCATION

  // Relations
  senderId       Int
  recipientId    Int
  serviceOrderId Int

  // Attachment fields (optional)
  attachmentUrl  String?
  attachmentName String?
  attachmentType String? // MIME type
  attachmentSize Int?    // bytes

  // Location fields (optional)
  locationLat    Float?
  locationLng    Float?
  locationLabel  String?

  // Extra metadata (e.g. hire_proposal action, checkoutUrl)
  metadata Json?

  sender       User         @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient    User         @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  isGroup    Boolean     @default(false)
  isArchived Boolean     @default(false)
  teamId     Int?
  team       ServiceTeam? @relation(fields: [teamId], references: [id])

  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([senderId])
  @@index([recipientId])
  @@index([serviceOrderId])
  @@index([createdAt])
  @@index([serviceOrderId, recipientId, isRead])
}

model File {
  id           Int     @id @default(autoincrement())
  filename     String
  originalName String
  mimeType     String
  size         Int // Em bytes
  url          String  @unique
  description  String?

  // Relations
  userId         Int
  serviceOrderId Int?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([serviceOrderId])
  @@index([createdAt])
}

model Certification {
  id              Int       @id @default(autoincrement())
  title           String
  issuer          String
  issueDate       DateTime
  expiryDate      DateTime?
  credentialId    String?
  verificationUrl String?

  // Relations
  professionalId Int

  professional User @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([professionalId])
}

model VerificationSubmission {
  id              Int                        @id @default(autoincrement())
  userId          Int
  type            VerificationType
  status          VerificationSubmissionStatus @default(PENDING)
  metadata        Json?
  rejectionReason String?
  submittedAt     DateTime                   @default(now())
  reviewedAt      DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([submittedAt])
}

model EscrowConfig {
  id                    Int     @id @default(autoincrement())
  name                  String  @unique
  description           String?
  defaultHoldDays       Int     @default(7) // Dias padrão que o pagamento fica em escrow
  autoReleaseDays       Int     @default(2) // Dias após conclusão para liberação automática
  disputePeriodDays     Int     @default(3) // Período para abrir disputa após liberação
  platformFeePercentage Float   @default(10.0) // Taxa da plataforma
  minServiceValue       Float   @default(0.0)
  maxServiceValue       Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tabela de configuração do sistema
model SystemConfig {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  value       Json
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ============================================
// SMART BRIEF, PROPOSALS, SCHEDULING, DISPUTES
// ============================================

model OrderBrief {
  id             Int      @id @default(autoincrement())
  serviceOrderId Int      @unique
  categoryId     Int?
  urgencyLevel   String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  priceRangeMin  Float?
  priceRangeMax  Float?
  briefData      Json     // Category-specific form data as JSON
  mediaUrls      Json?    // Array of photo/video URLs
  notes          String?

  serviceOrder ServiceOrder     @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  category     ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceOrderId])
  @@index([categoryId])
}

model Proposal {
  id              Int      @id @default(autoincrement())
  serviceOrderId  Int
  professionalId  Int
  price           Float
  estimatedDays   Int?
  estimatedHours  Int?
  description     String
  guaranteeDays   Int?     // Warranty period in days
  status          String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, WITHDRAWN
  metadata        Json?

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  professional User         @relation("ProposalProfessional", fields: [professionalId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceOrderId, professionalId])
  @@index([serviceOrderId])
  @@index([professionalId])
  @@index([status])
}

model ProfessionalSchedule {
  id              Int      @id @default(autoincrement())
  professionalId  Int
  dayOfWeek       Int      // 0=Sunday, 6=Saturday
  startTime       String   // "08:00"
  endTime         String   // "18:00"
  isAvailable     Boolean  @default(true)

  professional User @relation("ProfessionalSchedule", fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
  @@index([professionalId])
}

model ScheduleBlock {
  id              Int      @id @default(autoincrement())
  professionalId  Int
  startDateTime   DateTime
  endDateTime     DateTime
  reason          String?  // "Pedido #123", "Folga", etc.
  serviceOrderId  Int?     @unique

  professional   User          @relation("ScheduleBlocks", fields: [professionalId], references: [id], onDelete: Cascade)
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)

  @@index([professionalId])
  @@index([startDateTime, endDateTime])
}

model Dispute {
  id              Int      @id @default(autoincrement())
  serviceOrderId  Int
  initiatorId     Int
  reason          String
  description     String
  status          String   @default("OPEN") // OPEN, UNDER_REVIEW, RESOLVED, CLOSED
  resolution      String?
  attachments     Json?    // Array of file URLs
  metadata        Json?

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  initiator    User         @relation("DisputeInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceOrderId])
  @@index([initiatorId])
  @@index([status])
}

// ============================================
// ENTERPRISE / COMPANY MODELS
// ============================================

model CompanyProfile {
  id           Int       @id @default(autoincrement())
  userId       Int       @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  cnpj         String    @unique
  description  String?
  logo         String?
  coverImage   String?
  website      String?
  phone        String?
  address      Json?
  isVerified   Boolean   @default(false)
  industry     String?
  foundedAt    DateTime?
  createdAt    DateTime  @default(now())

  members  CompanyMember[]
  roles    CompanyRole[]
  channels CompanyChannel[]
}

model CompanyRole {
  id          Int            @id @default(autoincrement())
  companyId   Int
  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  level       Int
  permissions Json
  color       String?
  createdAt   DateTime       @default(now())

  members     CompanyMember[]
  salaryRules CompanySalaryRule[]
}

model CompanyMember {
  id                Int            @id @default(autoincrement())
  companyId         Int
  company           CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId            Int            @unique
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId            Int
  role              CompanyRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  customPermissions Json?
  joinedAt          DateTime       @default(now())
  isActive          Boolean        @default(true)

  salaryHistory   CompanySalaryPayment[]
  teamMemberships ServiceTeamMember[]
  ledTeams        ServiceTeam[]          @relation("TeamLeader")
  channelMemberships CompanyChannelMember[]
}

model CompanySalaryRule {
  id          Int            @id @default(autoincrement())
  companyId   Int
  roleId      Int?
  role        CompanyRole?   @relation(fields: [roleId], references: [id])
  memberId    Int?
  amount      Float
  dayOfMonth  Int
  description String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())

  payments CompanySalaryPayment[]
}

model CompanySalaryPayment {
  id       Int               @id @default(autoincrement())
  ruleId   Int
  rule     CompanySalaryRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  memberId Int
  member   CompanyMember     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount   Float
  paidAt   DateTime
  status   SalaryStatus
  note     String?
}

model ServiceTeam {
  id        Int           @id @default(autoincrement())
  orderId   Int           @unique
  order     ServiceOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  leaderId  Int
  leader    CompanyMember @relation("TeamLeader", fields: [leaderId], references: [id])
  createdAt DateTime      @default(now())

  members  ServiceTeamMember[]
  messages Message[]
}

model ServiceTeamMember {
  id       Int           @id @default(autoincrement())
  teamId   Int
  team     ServiceTeam   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  memberId Int
  member   CompanyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
}


model CompanyChannel {
  id          Int            @id @default(autoincrement())
  companyId   Int
  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())

  members     CompanyChannelMember[]
}

model CompanyChannelMember {
  id        Int            @id @default(autoincrement())
  channelId Int
  channel   CompanyChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  memberId  Int
  member    CompanyMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([channelId, memberId])
}

// ============================================
// ANALYTICS / SESSION TRACKING
// ============================================

model UserSession {
  id          String     @id @default(uuid())
  userId      Int
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt   DateTime   @default(now())
  endedAt     DateTime?
  duration    Int?
  pagesViewed Int        @default(0)
  device      String?
  pageViews   PageView[]
  createdAt   DateTime   @default(now())

  @@index([userId])
  @@index([startedAt])
}

model PageView {
  id        String      @id @default(uuid())
  sessionId String
  session   UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  path      String
  enteredAt DateTime    @default(now())
  duration  Int?

  @@index([sessionId])
  @@index([path])
  @@index([enteredAt])
}
