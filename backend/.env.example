# Server
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Database
DATABASE_URL=file:./dev.db

# Authentication
JWT_SECRET=your-secret-here-min-32-chars-for-production
JWT_ACCESS_SECRET=    # Separate access token secret (falls back to JWT_SECRET)
JWT_REFRESH_SECRET=   # Separate refresh token secret (falls back to JWT_SECRET)
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# Security
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
BODY_SIZE_LIMIT=10kb

# Escrow
DEFAULT_ESCROW_HOLD_DAYS=7
ESCROW_AUTO_RELEASE_DAYS=2
PLATFORM_FEE_PERCENTAGE=10.0

# Mercado Pago (NUNCA commitar valores reais!)
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_SANDBOX=true

# Webhook secret from MercadoPago dashboard (required in production)
MP_WEBHOOK_SECRET=

# Notifications
ENABLE_EMAIL_NOTIFICATIONS=false

# Email (SMTP - Brevo em produção, Ethereal em dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=FazTudo
SMTP_FROM_EMAIL=noreply@faztudo.com.br

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5173

# Dev only: allow payment bypass without real MercadoPago (NEVER set to true in production)
ALLOW_LOCAL_PAYMENT_FALLBACK=false
